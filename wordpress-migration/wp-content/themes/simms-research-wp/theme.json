        },
        {
          "slug": "neue-montreal",
          "name": "PP Neue Montreal",
          "fontFamily": "'PP Neue Montreal', system-ui, -apple-system, Segoe UI, sans-serif"
        },
        {
          "slug": "geist-mono",
          "name": "Geist Mono",
          "fontFamily": "'Geist Mono', ui-monospace, SFMono-Regular, Menlo, Consolas, monospace"
        }
      ]
    }
  }
}

